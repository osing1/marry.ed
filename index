            top: -36px;
            left: 50%;
            transform: translateX(-50%);
            opacity: 0;
            width: 0;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .nav-item:hover .nav-tooltip {
            opacity: 1;
            width: max-content;
        }
        
        /* Background Carousel */
        .bg-carousel-item {
