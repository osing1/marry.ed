    <script>
        document.addEventListener('DOMContentLoaded', () => {
            /* 1. Global Slideshow (Opactiy 30% Fixed Background) */
            const bgImages = document.querySelectorAll('.bg-carousel-item');
            let currentBgIndex = 0;
            setInterval(() => {
                bgImages[currentBgIndex].classList.remove('active');
                currentBgIndex = (currentBgIndex + 1) % bgImages.length;
                bgImages[currentBgIndex].classList.add('active');
            }, 5000); // Crossfade every 5 seconds

            /* 2. Opening Cover Page Logic */
            const btnOpen = document.getElementById('btn-open');
            const coverPage = document.getElementById('cover-page');
            const bottomNav = document.getElementById('bottom-nav');
            const audio = document.getElementById('bg-music');
            
            // Remove initial loading dots
            setTimeout(() => {
                document.getElementById('loading-dots').style.opacity = '0';
                setTimeout(() => document.getElementById('loading-dots').style.display = 'none', 500);
                
                // Slide up intro cover images
                document.body.classList.add('loaded');
                document.getElementById('cover-content').classList.remove('opacity-0');
            }, 500);

            btnOpen.addEventListener('click', () => {
                // Slide up the cover
                coverPage.style.transform = 'translateY(-100%)';
                setTimeout(() => coverPage.style.display = 'none', 1000);
                
                // Show bottom nav
                bottomNav.classList.remove('translate-y-24');
                
                // Play music
                audio.play();
            });

            /* 3. Music Toggle Logic */
            const btnMusicToggle = document.getElementById('btn-music-toggle');
            const iconWrapper = document.getElementById('music-icon-wrapper');
            const musicTooltipText = document.getElementById('music-tooltip-text');
            
            // Music ON SVG 
            const svgMusicOn = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path d="M9 17v-13h10v13"></path><path d="M9 8h10"></path></svg>`;
            // Music OFF SVG (Same as original prompt)
            const svgMusicOff = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path d="M14.42 14.45a3 3 0 1 0 4.138 4.119"></path><path d="M9 17v-8m0 -4v-1h10v11"></path><path d="M12 8h7"></path><path d="M3 3l18 18"></path></svg>`;
            
            let isMusicPlaying = true; // Auto assumed true after pressing Buka
            
            btnMusicToggle.addEventListener('click', () => {
                if(isMusicPlaying) {
                    audio.pause();
                    iconWrapper.innerHTML = svgMusicOff;
                    musicTooltipText.innerText = "Musik dihentikan";
                } else {
                    audio.play();
                    iconWrapper.innerHTML = svgMusicOn;
                    musicTooltipText.innerText = "Musik diputar";
                }
                isMusicPlaying = !isMusicPlaying;
            });

            /* 4. Cerita Carousel Scroll Progress */
            const ceritaCarousel = document.getElementById('cerita-carousel');
            const ceritaProgress = document.getElementById('cerita-progress');
            
            ceritaCarousel.addEventListener('scroll', () => {
                const scrollLeft = ceritaCarousel.scrollLeft;
                const scrollWidth = ceritaCarousel.scrollWidth - ceritaCarousel.clientWidth;
                // Calculate percentage, min 1/6 (16.66%) max 100%
                let percentage = (scrollLeft / scrollWidth) * 100;
                let actualWidth = 16.66 + (percentage * 0.8334);
                ceritaProgress.style.width = actualWidth + '%';
            });

            /* 5. Scroll Reveal Intersection Observer */
            const revealElements = document.querySelectorAll('.reveal-elem');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { 
                threshold: 0.1, 
                rootMargin: "0px 0px -50px 0px" 
            });

            revealElements.forEach(el => observer.observe(el));
        });
    </script>
